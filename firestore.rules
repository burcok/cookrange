rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isParticipant(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.participants;
    }

    function isPostOwner(postData) {
      return isAuthenticated() && request.auth.uid == postData.authorId;
    }

    function isSignalOwner(signalData) {
      return isAuthenticated() && request.auth.uid == signalData.userId;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/admin/status/$(request.auth.uid)).data.is_admin == true;
    }

    // Validate that only allowed fields are being written
    function hasNoExtraFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    // Fields on the user doc that are SERVER-AUTHORITATIVE — clients may never
    // write them. Entitlements, AI credits, ban state, and the referral marker
    // are set ONLY by Cloud Functions (Admin SDK, which bypasses rules) or by an
    // admin. This closes premium / AI-credit self-grant and ban-evasion via
    // direct user-doc writes (audit C1, C2, C3, C7).
    //
    // NOTE: user_roles/user_role are intentionally NOT locked here. The app's
    // self-service model lets a user become coach/gymOwner (coach_service /
    // gym_service write their own roles), and coach/gym FEATURES are gated by
    // ownership, not by this array. True admin power is gated server-side by
    // admin/status/{uid} (deny-all to clients) — a self-written user_roles:
    // ['admin'] only reveals client admin UI (cosmetic, M18), never real admin
    // capability. Gating that UI on a server claim is a separate follow-up.
    function touchesProtectedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'subscription_tier', 'subscription_expires_at', 'subscription_product_id',
        'subscription_purchase_token', 'ai_credits_used', 'ai_credits_reset_at',
        'ai_credits_bonus', 'referral_used', 'is_banned'
      ]);
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read any profile (needed for search, friend lists, chat presence)
      allow read: if isAuthenticated();
      // Only the owner can create/update their own document.
      allow create: if isOwner(uid);
      // Owner may update only NON-privileged fields; privileged fields
      // (entitlements/credits/roles/ban/referral) are server/admin-written and
      // rejected here for clients. Admin (server) retains full update.
      allow update: if (isOwner(uid) && !touchesProtectedUserFields())
        || isAdmin();
      allow delete: if isOwner(uid);

      // Friends subcollection: owner reads; either party can create; owner can delete
      match /friends/{friendId} {
        allow read: if isOwner(uid);
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isOwner(uid);
      }

      // Friend requests subcollection
      match /friend_requests/{requestId} {
        allow read: if isOwner(uid);
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isOwner(uid) || isOwner(requestId);
      }

      // Notifications: owner reads; any authenticated user can create (for sending notifs to others)
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow create: if isAuthenticated();
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // Meal plans: strictly owner-only
      match /meal_plans/{planId} {
        allow read, write: if isOwner(uid);
      }

      // Food logs: strictly owner-only
      match /food_logs/{logId} {
        allow read, write: if isOwner(uid);
      }

      // Favorites (bookmarked recipes): strictly owner-only
      match /favorites/{recipeId} {
        allow read, write: if isOwner(uid);
      }

      // Shopping list
      match /lists/{listId} {
        allow read, write: if isOwner(uid);
      }

      // Recent foods for quick-add
      match /recent_foods/{foodId} {
        allow read, write: if isOwner(uid);
      }

      // AI food-analysis history: strictly owner-only
      match /food_analyses/{analysisId} {
        allow read, write: if isOwner(uid);
      }

      // Saved/bookmarked community posts
      match /saved_posts/{postId} {
        allow read, write: if isOwner(uid);
      }

      // Notification preferences
      match /notification_preferences/{prefId} {
        allow read, write: if isOwner(uid);
      }

      // Exercise / activity logs
      match /exercise_logs/{logId} {
        allow read, write: if isOwner(uid);
      }

      // Personal recipe notes
      match /recipe_notes/{recipeId} {
        allow read, write: if isOwner(uid);
      }

      // Private PII subcollection (nutrition profile) — owner-only; never
      // readable by other authenticated users regardless of friendship status.
      match /private/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── Logs (auth/session/activity audit trail) ───────────────────────────
    match /logs/{userId} {
      // Only the owner can read; auth service can write (uses server-side patterns)
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ─── Failed login attempts (security monitoring) ────────────────────────
    match /failed_login_attempts/{docId} {
      // Server-only: an UNAUTHENTICATED `create: if true` let anyone spam this
      // collection (write-amplification / billing abuse, audit C7). Failed-login
      // monitoring must come from Identity Platform / an Auth blocking function,
      // not unauthenticated client writes. The client writer is best-effort and
      // tolerates this denial.
      allow create, read, update, delete: if false;
    }

    // ─── Dishes (read-only catalog for users) ───────────────────────────────
    match /dishes/{dishId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ─── App Settings (public-read config; admin-managed) ────────────────────
    // e.g. settings/content_filter holds the moderation word-list, mirrored here
    // from admin_config so the client filter (all users) can read it.
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Community Posts ─────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.get('content', '').size() <= 5000;
      allow update: if isAuthenticated()
        && (isPostOwner(resource.data)
          // Allow like/reaction counter updates from any authenticated user
          || (!request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['authorId', 'content', 'imageUrls', 'tags'])));
      allow delete: if isAuthenticated() && isPostOwner(resource.data);

      // Comments
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.get('content', '').size() <= 2000;
        allow update: if isAuthenticated()
          && (resource.data.authorId == request.auth.uid
            || (!request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['authorId', 'content'])));
        allow delete: if isAuthenticated()
          && resource.data.authorId == request.auth.uid;

        // Comment likes
        match /likes/{userId} {
          allow read: if isAuthenticated();
          allow write: if isOwner(userId);
        }
      }

      // Post likes
      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      // Post reactions
      match /reactions/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }

    // ─── Chats ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated() && isParticipant(resource.data);
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && isParticipant(resource.data);
      allow delete: if false; // Chats are never deleted client-side

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isAuthenticated()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.get('text', '').size() <= 5000;
        allow update: if isAuthenticated()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow delete: if false;
      }
    }

    // ─── Signals (ephemeral social broadcasts) ────────────────────────────────
    match /signals/{signalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('message', '').size() <= 2000;
      allow update: if isAuthenticated()
        && (isSignalOwner(resource.data)
          // Allow others to add themselves to ignoredBy list
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ignoredBy']));
      allow delete: if isAuthenticated() && isSignalOwner(resource.data);
    }

    // ─── Reports (write-only for authenticated users; read restricted to admin) ─
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ─── Privacy / data-subject requests (DSAR — KVKK/GDPR) ───────────────────
    // Owner files + reads own; admin reads + updates (status/notes). No deletion.
    match /privacy_requests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAuthenticated()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Block list (per-user, full CRUD by owner only) ──────────────────────
    match /users/{uid}/block_list/{blockedId} {
      allow read, write: if isOwner(uid);
    }

    // ─── Challenges ──────────────────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;
      // Only creator can update title/desc/goal; any participant can update progress field
      allow update: if isAuthenticated()
        && (resource.data.createdBy == request.auth.uid
            || request.auth.uid in resource.data.participantIds);
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Referral codes ───────────────────────────────────────────────────────
    match /referrals/{code} {
      // Any authenticated user may read a referral doc (to validate a code).
      allow read: if isAuthenticated();
      // Only the owner may create their own referral doc.
      allow create: if isAuthenticated()
        && request.resource.data.owner_uid == request.auth.uid;
      // The applying user is added to used_by_uids ONLY by the applyReferral
      // Cloud Function (Admin SDK, bypasses rules), and rewards are server-
      // granted. A client may update a code doc only if it OWNS the code (coach
      // vanity / settings) or is admin, and may never change owner_uid — so a
      // non-owner can no longer rewrite usage or self-grant (audit C8).
      allow update: if isAuthenticated()
        && (resource.data.owner_uid == request.auth.uid || isAdmin())
        && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if false;
    }

    // ─── Gyms ────────────────────────────────────────────────────────────────
    // ─── Community Groups ─────────────────────────────────────────────────────
    match /community_groups/{groupId} {
      // Any authenticated user can read groups (discovery).
      allow read: if isAuthenticated();
      // Creator must own the group.
      allow create: if isAuthenticated()
        && request.resource.data.owner_uid == request.auth.uid;
      // Owner/admin can edit freely; any member may bump only the counter
      // fields (member_count / last_activity_at) on join/leave/post.
      allow update: if isAuthenticated()
        && (resource.data.owner_uid == request.auth.uid
            || isAdmin()
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['member_count', 'last_activity_at', 'updated_at']));
      allow delete: if isAuthenticated()
        && (resource.data.owner_uid == request.auth.uid || isAdmin());

      // Members subcollection: a user manages their own membership doc;
      // the group owner (and admin) may manage any.
      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && (request.auth.uid == memberId
              || get(/databases/$(database)/documents/community_groups/$(groupId)).data.owner_uid == request.auth.uid
              || isAdmin());
      }
    }

    match /gyms/{gymId} {
      // Any authenticated user can read gym profiles (for search/discovery)
      allow read: if isAuthenticated();
      // Only the gym owner can create/update their gym
      allow create: if isAuthenticated()
        && request.resource.data.owner_uid == request.auth.uid;
      // Owner updates gym; admin may set is_verified badge.
      allow update: if isAuthenticated()
        && (resource.data.owner_uid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated()
        && resource.data.owner_uid == request.auth.uid;

      // Gym members subcollection — owner manages, members can read their own entry
      match /members/{memberId} {
        allow read: if isAuthenticated()
          && (get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid
              || request.auth.uid == memberId);
        allow write: if isAuthenticated()
          && (get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid
              || isAdmin());
      }

      // Gym community posts
      match /posts/{postId} {
        // Any authenticated user can read posts
        allow read: if isAuthenticated();
        // Any authenticated user can create a post (membership enforced app-side)
        allow create: if isAuthenticated()
          && request.resource.data.author_uid == request.auth.uid;
        // Author can update their own post content; owner can update any field;
        // any authenticated user can update like fields only
        allow update: if isAuthenticated()
          && (resource.data.author_uid == request.auth.uid
            || get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid
            || !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['author_uid', 'content', 'is_announcement']));
        allow delete: if isAuthenticated()
          && (resource.data.author_uid == request.auth.uid
            || get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid);

        // Post comments
        match /comments/{commentId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated()
            && request.resource.data.author_uid == request.auth.uid;
          allow update: if isAuthenticated()
            && resource.data.author_uid == request.auth.uid;
          allow delete: if isAuthenticated()
            && (resource.data.author_uid == request.auth.uid
              || get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid);
        }
      }

      // Check-in records
      match /checkins/{checkinId} {
        allow read: if isAuthenticated()
          && (get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_uid == request.auth.uid
              || request.auth.uid == resource.data.uid);
        allow create: if isAuthenticated()
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ─── Gym Wars ─────────────────────────────────────────────────────────────
    match /gym_wars/{warId} {
      // Any authenticated user can read wars (for discovery)
      allow read: if isAuthenticated();
      // Only the challenger (gym owner) can create a war
      allow create: if isAuthenticated()
        && request.resource.data.challenger_uid == request.auth.uid;
      // Only the challenger can update (e.g. end the war)
      allow update: if isAuthenticated()
        && resource.data.challenger_uid == request.auth.uid;
      allow delete: if false;
    }

    // ─── Coach Profiles ───────────────────────────────────────────────────────
    match /coach_profiles/{coachUid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(coachUid);
      // Owner updates their own profile; admin may set is_verified badge.
      allow update: if isOwner(coachUid) || isAdmin();
      allow delete: if false;

      match /clients/{clientUid} {
        // Coach reads all clients; client reads own entry
        allow read: if isAuthenticated()
          && (request.auth.uid == coachUid || request.auth.uid == clientUid);
        // Client creates request for themselves; coach updates status
        allow create: if isAuthenticated() && request.auth.uid == clientUid;
        allow update: if isAuthenticated()
          && (request.auth.uid == coachUid || request.auth.uid == clientUid);
        allow delete: if false;
      }
    }

    // ─── Programs (marketplace) ───────────────────────────────────────────────
    match /programs/{programId} {
      // Any authenticated user can browse published programs
      allow read: if isAuthenticated();
      // Coach creates their own programs; 'demo' coach_uid is reserved for the
      // DemoContentSeeder which writes demo marketplace content on first install.
      allow create: if isAuthenticated()
        && (request.resource.data.coach_uid == request.auth.uid
            || request.resource.data.coach_uid == 'demo');
      // Owning coach can update/delete; admin can update status (approve/reject).
      allow update: if isAuthenticated()
        && (resource.data.coach_uid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated()
        && resource.data.coach_uid == request.auth.uid;

      // Week content subcollection — any enrolled user or owner may read.
      // Writes restricted to the owning coach or demo seeder.
      match /weeks/{weekId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && (get(/databases/$(database)/documents/programs/$(programId)).data.coach_uid == request.auth.uid
              || get(/databases/$(database)/documents/programs/$(programId)).data.coach_uid == 'demo');
      }
    }

    // ─── Seeds (idempotent seeder gates) ──────────────────────────────────────
    // Used by client-side seeders (DemoContentSeeder, etc.) to record completed
    // seed runs. Any authenticated user may read or write — the seeder checks the
    // flag before writing, so this is safe to leave open to authenticated clients.
    match /seeds/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Program enrollments: owner-only
    match /users/{uid}/program_enrollments/{programId} {
      allow read, write: if isOwner(uid);
    }

    // ─── Commission earnings (per-user subcollection) ─────────────────────────
    match /users/{uid}/commissions/{commissionId} {
      // Owner reads their own commissions. Writes are SERVER-ONLY — commissions
      // are recorded by Cloud Functions after validation, never by clients
      // (closes forgeable-earnings → payout fraud, audit C8).
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    // ─── Coaching requests (client→coach) ────────────────────────────────────
    // Path: users/{coachUid}/coaching_requests/{clientUid}
    // Coach reads their own requests; client reads/writes their own request doc.
    match /users/{uid}/coaching_requests/{requestDoc} {
      allow read: if isAuthenticated()
        && (request.auth.uid == uid || request.auth.uid == requestDoc);
      allow write: if isAuthenticated() && request.auth.uid == requestDoc;
    }

    // ─── Payout requests ──────────────────────────────────────────────────────
    match /users/{uid}/payout_requests/{requestId} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── AI twin projections (history) ────────────────────────────────────────
    match /users/{uid}/ai_twin_projections/{doc} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── AI weekly recaps (owner-only) ────────────────────────────────────────
    match /users/{uid}/ai_weekly_recaps/{doc} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── Achievements / badges (owner-only) ───────────────────────────────────
    match /users/{uid}/achievements/{achievementKey} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── Consent records (KVKK/GDPR — demonstrable, versioned, owner-only) ─────
    match /users/{uid}/consents/{purpose} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── Coach applications ────────────────────────────────────────────────────
    // Applicant can read/write their own; admin can read/write all.
    match /coach_applications/{appId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.applicantUid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.applicantUid == request.auth.uid;
      allow update: if isAuthenticated() && isAdmin();
    }

    // ─── Gym applications ──────────────────────────────────────────────────────
    match /gym_applications/{appId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.applicantUid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.applicantUid == request.auth.uid;
      allow update: if isAuthenticated() && isAdmin();
    }

    // ─── Admin audit log (append-only, admin-read-only) ─────────────────────
    // Path: admin_audit/{id}
    // Written by admin actions (AdminService.logAuditAction). Only admins can
    // read; nobody can update or delete — this is an immutable audit trail.
    match /admin_audit/{id} {
      allow create: if isAuthenticated() && isAdmin();
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    // ─── Admin Config (feature flags + maintenance + AI model) ───────────────
    // Admin reads/writes; app reads only maintenance_mode and min_version via
    // admin_status_service (Firestore-first, RC fallback). No user access.
    match /admin_config/{docId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ─── Broadcasts (admin push + in-app announcements) ───────────────────────
    // Admins create and read; Cloud Functions update status/counts; nobody deletes.
    match /broadcasts/{id} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin()
        && request.resource.data.admin_uid == request.auth.uid;
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if false;
    }

    // ─── Streak Squads ────────────────────────────────────────────────────────
    // Members can read their own squads; any authenticated user can create;
    // members can update; only the creator can delete.
    match /squads/{squadId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.memberUids;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.creatorUid
        && request.auth.uid in request.resource.data.memberUids;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.memberUids;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.creatorUid;
    }

    // ─── Coach Reviews ────────────────────────────────────────────────────────
    // Path: coach_profiles/{coachUid}/reviews/{reviewerUid}
    // Linked clients create one review (doc id = reviewerUid); all authenticated
    // users read; reviews are immutable once submitted (no update/delete).
    match /coach_profiles/{coachUid}/reviews/{reviewerUid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == reviewerUid
        && request.resource.data.reviewerUid == reviewerUid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if false;
    }

    // ─── Follow relationships ─────────────────────────────────────────────────
    // Following list: owner writes their own; any authenticated user reads.
    match /users/{uid}/following/{targetUid} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(uid);
      allow update: if false;
    }

    // Followers list: any authenticated user creates/deletes their own entry.
    match /users/{uid}/followers/{sourceUid} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated() && request.auth.uid == sourceUid;
      allow update: if false;
    }

    // ─── AI credit ledger (server-authoritative) ─────────────────────────────
    // Written by Cloud Functions (aiProxy / purchase validation) via the Admin
    // SDK, or by an admin (panel comps; audited). Owner may READ for the credit
    // badge; regular users can never write (audit C1/C3).
    match /ai_credits/{uid} {
      allow read: if isOwner(uid);
      allow write: if isAdmin();
    }

    // ─── Entitlements (premium tier; server-authoritative) ────────────────────
    // Written by the purchase-validation / referral Cloud Functions, or by an
    // admin (comp premium; audited). Owner may READ; premium is never
    // client-grantable by regular users (audit C7).
    match /entitlements/{uid} {
      allow read: if isOwner(uid);
      allow write: if isAdmin();
    }

    // ─── Processed purchase tokens (replay/dedupe guard; fully server-only) ───
    match /processed_purchases/{id} {
      allow read, write: if false;
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
